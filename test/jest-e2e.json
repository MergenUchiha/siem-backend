{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "collectCoverageFrom": [
    "../src/**/*.ts",
    "!../src/main.ts",
    "!../src/**/*.module.ts"
  ],
  "coverageDirectory": "../coverage-e2e"
}